# =========================================================
# SOC PLATFORM — CONFIGURATION ENVIRONNEMENT
# SIEM / SOAR / SIMULATION / TEST AUTOMATION
# =========================================================

# Base URL des webhooks n8n (obligatoire)
BASE_URL=https://your-n8n-instance.app.n8n.cloud/webhook

# =========================================================
# AUTH TOKENS (SECURITY LAYER - API GATEWAY)
# =========================================================

# SIEM ingestion API
SIEM_TOKEN=replace_with_siem_token

# SOAR orchestrator
ORCH_TOKEN=replace_with_orch_token

# SOAR brute force response engine
SOAR_BF_TOKEN=replace_with_bruteforce_token

# SOAR phishing response engine
SOAR_PH_TOKEN=replace_with_phishing_token

# Simulation engine (EDR / firewall / endpoint)
SIM_TOKEN=replace_with_simulation_token

# Reporting / dashboard API
REPORT_TOKEN=replace_with_report_token

# API Gateway security token
GATEWAY_TOKEN=replace_with_gateway_token

# =========================================================
# ANALYST / COMMUNICATION LAYER
# =========================================================

# SOC analyst phone 
ANALYST_L1= +1 (XXX) XXX-XXXX

# Skip WhatsApp automation during tests (true/false)
SKIP_WHATSAPP=true

# =========================================================
# TWILIO / RELAY SECURITY (OPTIONAL BUT RECOMMENDED)
# =========================================================

# Twilio relay endpoint (HMAC verification layer)
RELAY_URL=https://your-relay-service.com

# =========================================================
# OPTIONAL — FUTURE EXTENSIONS
# =========================================================

# Threat Intelligence API (AbuseIPDB / VirusTotal)
TI_API_KEY=your_threat_intel_api_key

# Supabase / Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key

# Dashboard / frontend integration
DASHBOARD_URL=https://your-soc-dashboard.com
